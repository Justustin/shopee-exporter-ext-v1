# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-random-string

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/shopee_saas
# For Neon, prefer putting ?sslmode=require in DATABASE_URL and keeping DATABASE_SSL=false.
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# License backend
LICENSE_PEPPER=change-me-to-a-random-string
LICENSE_VERIFICATION_RETENTION_DAYS=90
ADMIN_EMAILS=admin@example.com
SUPPORT_EMAIL=support@example.com
SUPPORT_WHATSAPP=
ALLOW_SELF_REGISTRATION=true

# Shopee Open Platform
ENABLE_SHOPEE_PLATFORM=false
SHOPEE_PARTNER_ID=your_partner_id
SHOPEE_PARTNER_KEY=your_partner_key
SHOPEE_REDIRECT_URL=http://localhost:3000/shopee/auth/callback

# Token encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=64-char-hex-string-here
